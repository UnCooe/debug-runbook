{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunbookSelectorMetadata",
  "type": "object",
  "required": ["name", "priority", "context_types", "positive_signals", "negative_signals"],
  "properties": {
    "name": { "type": "string" },
    "priority": { "type": "number" },
    "context_types": { "type": "array", "items": { "type": "string" } },
    "positive_signals": { "$ref": "#/defs/signalArray" },
    "negative_signals": { "$ref": "#/defs/signalArray" }
  },
  "additionalProperties": false,
  "defs": {
    "signalArray": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pattern", "weight"],
        "properties": {
          "pattern": { "type": "string" },
          "weight": { "type": "number" },
          "mode": { "type": "string", "enum": ["regex"] }
        },
        "additionalProperties": false
      }
    }
  }
}

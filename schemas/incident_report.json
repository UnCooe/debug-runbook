{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IncidentReport",
  "type": "object",
  "required": [
    "incident_summary",
    "confirmed_facts",
    "most_likely_root_cause",
    "evidence",
    "recommended_next_actions"
  ],
  "properties": {
    "incident_summary": {
      "type": "string"
    },
    "confirmed_facts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "most_likely_root_cause": {
      "type": "string"
    },
    "alternative_hypotheses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "./evidence.json"
      }
    },
    "recommended_next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
